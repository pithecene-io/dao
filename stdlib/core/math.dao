module core::math
fn min<T: Numeric>(a: T, b: T): T
  if a.less_than(b):
    return a
  return b

fn max<T: Numeric>(a: T, b: T): T
  if b.less_than(a):
    return a
  return b

fn clamp<T: Numeric>(x: T, lo: T, hi: T): T
  if x.less_than(lo):
    return lo
  if hi.less_than(x):
    return hi
  return x

fn abs(x: i32): i32
  if x < 0:
    return 0 - x
  return x

fn abs_f64(x: f64): f64
  if x < 0.0:
    return 0.0 - x
  return x
