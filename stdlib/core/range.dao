module core::range
fn range(n: i32): Generator<i32>
  let i: i32 = 0
  while i < n:
    yield i
    i = i + 1

fn range(start: i32, end: i32): Generator<i32>
  let i: i32 = start
  while i < end:
    yield i
    i = i + 1

fn range(start: i32, end: i32, step: i32): Generator<i32>
  let i: i32 = start
  if step > 0:
    while i < end:
      yield i
      i = i + step
  else:
    if step < 0:
      while i > end:
        yield i
        i = i + step
