[settings]
arch=x86_64
build_type=Debug
compiler=clang
compiler.cppstd=23
compiler.libcxx=libstdc++11
compiler.version=21
os=Linux

[conf]
tools.build:compiler_executables={"c": "clang", "cpp": "clang++"}
