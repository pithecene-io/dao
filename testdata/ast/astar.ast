File
  AliasDecl NodeId = i32
  FunctionDecl heuristic
    Param a: NodeId
    Param b: NodeId
    ReturnType: i32
    ExprBody
      BinaryExpr +
        Identifier a
        Identifier b
  FunctionDecl reconstruct_path
    Param came_from: i32
    Param start: NodeId
    Param goal: NodeId
    ReturnType: i32
    ExprBody
      BinaryExpr +
        Identifier start
        Identifier goal
  FunctionDecl a_star
    Param start: NodeId
    Param goal: NodeId
    ReturnType: i32
    IfStatement
      Condition
        BinaryExpr ==
          Identifier start
          Identifier goal
      Then
        ReturnStatement
          CallExpr
            Callee
              Identifier reconstruct_path
            Args
              IntLiteral 0
              Identifier start
              Identifier goal
    LetStatement cost: i32
      CallExpr
        Callee
          Identifier heuristic
        Args
          Identifier start
          Identifier goal
    ReturnStatement
      Identifier cost
