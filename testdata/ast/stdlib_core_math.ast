  FunctionDecl abs
    Param x: i32
    ReturnType: i32
    IfStatement
      Condition
        BinaryExpr <
          Identifier x
          IntLiteral 0
      Then
        ReturnStatement
          BinaryExpr -
            IntLiteral 0
            Identifier x
    ReturnStatement
      Identifier x
  FunctionDecl abs_f64
    Param x: f64
    ReturnType: f64
    IfStatement
