fn countdown(from: i32): Generator<i32>
  let i: i32 = from
  while i > 0:
    yield i
    i = i - 1

fn evens(n: i32): Generator<i32>
  let i: i32 = 0
  while i < n:
    yield i * 2
    i = i + 1

fn main(): i32
  print("countdown from 5:")
  for x in countdown(5):
    print(x)

  print("first 4 even numbers:")
  for x in evens(4):
    print(x)

  print("sum of range(5):")
  let total: i32 = 0
  for i in range(5):
    total = total + i
  print(total)

  return 0
