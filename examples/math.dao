fn main(): i32
  print("min(10, 3):")
  print(min(10, 3))
  print("min(3.14, 2.71):")
  print(min(3.14, 2.71))
  print("max(10, 3):")
  print(max(10, 3))
  print("max(3.14, 2.71):")
  print(max(3.14, 2.71))
  print("clamp(15, 0, 10):")
  print(clamp(15, 0, 10))
  print("clamp(3.14, 1.0, 2.0):")
  print(clamp(3.14, 1.0, 2.0))
  print("abs(-5):")
  print(abs(0 - 5))
  print("abs_f64(-3.14):")
  print(abs_f64(0.0 - 3.14))
  print("length of hello:")
  print(length("hello"))
  return 0
