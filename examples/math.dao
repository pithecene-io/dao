fn main(): i32
  print("abs(-5):")
  print(abs(0 - 5))
  print("abs(3):")
  print(abs(3))
  print("min(10, 3):")
  print(min(10, 3))
  print("max(10, 3):")
  print(max(10, 3))
  print("clamp(15, 0, 10):")
  print(clamp(15, 0, 10))
  print("clamp(-5, 0, 10):")
  print(clamp(0 - 5, 0, 10))
  print("clamp(7, 0, 10):")
  print(clamp(7, 0, 10))
  print("length of hello:")
  print(length("hello"))
  return 0
