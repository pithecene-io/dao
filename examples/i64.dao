module i64
fn factorial_i64(n: i64): i64
  let result: i64 = 1
  let i: i64 = 1
  while i <= n:
    result = result * i
    i = i + 1
  return result

fn main(): i32
  print("factorial_i64(20):")
  print(factorial_i64(20))
  print("1 + x where x is i64:")
  let x: i64 = 100
  let y: i64 = 1 + x
  print(y)
  print("length of hello:")
  print(length("hello"))
  return 0
