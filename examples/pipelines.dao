module pipelines
fn double(x: i32): i32 -> x * 2

fn increment(x: i32): i32 -> x + 1

fn negate(x: i32): i32 -> 0 - x

fn transform(x: i32): i32 -> x |> double |> increment

fn main(): i32
  print("5 |> double |> increment:")
  print(transform(5))

  print("3 |> double |> negate:")
  let result: i32 = 3 |> double |> negate
  print(result)

  return 0
