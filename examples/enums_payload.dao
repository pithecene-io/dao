// enums_payload.dao — payload-bearing enum variants with match destructuring.

enum class Token:
  Int(value: i64)
  Plus
  Minus
  Eof

fn describe_token(t: Token): i32
  match t:
    Token.Int(value):
      print("Int: ")
      print(value)
      return 0
    Token.Plus:
      print("Plus")
      return 0
    Token.Minus:
      print("Minus")
      return 0
    Token.Eof:
      print("Eof")
      return 0
  return 0

fn main(): i32
  let t1: Token = Token.Int(to_i64(42))
  let t2: Token = Token.Plus
  let t3: Token = Token.Int(to_i64(99))

  describe_token(t1)
  describe_token(t2)
  describe_token(t3)

  return 0
